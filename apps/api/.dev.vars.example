# Copy to .dev.vars for local development. Never commit the real salt.
IP_HASH_SALT=replace-with-a-long-random-value
ALLOWED_ORIGINS=http://localhost:5173
DEMO_ONLY_MODE=false
EXPERIMENTAL_BROWSER_ENABLED=false
EXTERNAL_FETCH_ENABLED=true
FETCH_TIMEOUT_MS=10000
MAX_HTML_BYTES=1048576
MAX_REDIRECTS=5
RATE_LIMIT_DAILY_MAX=20
RATE_LIMIT_SHORT_MAX=5
RATE_LIMIT_SHORT_WINDOW_SECONDS=600
SMART_DETECTION_ENABLED=false
